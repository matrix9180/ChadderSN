<div class="container mx-auto px-4 py-8">
  <div class="max-w-4xl mx-auto">
    <div class="mb-8">
      <div class="flex items-center gap-4 mb-4">
        <%= link_to "← Back to Posts", posts_path, class: "btn btn-ghost btn-sm" %>
        <h1 class="text-3xl font-bold text-primary">#<%= @hashtag.name %></h1>
      </div>
      <p class="text-lg opacity-70">
        <%= pluralize(@hashtag.posts.count, 'post') %> with this hashtag
      </p>
    </div>

    <% if @posts.any? %>
      <div class="space-y-6">
        <% @posts.each do |post| %>
          <div class="card bg-base-100 shadow-xl">
            <div class="card-body">
              <div class="flex items-start gap-4">
                <div class="avatar">
                  <div class="w-12 h-12 rounded-full bg-primary text-primary-content flex items-center justify-center text-lg font-bold">
                    <%= post.author.username.first.upcase %>
                  </div>
                </div>
                <div class="flex-1">
                  <div class="flex items-center gap-2 mb-2">
                    <%= link_to post.author.username, user_path(post.author), class: "font-semibold hover:text-primary" %>
                    <span class="text-sm opacity-50">•</span>
                    <span class="text-sm opacity-50"><%= time_ago_in_words(post.created_at) %> ago</span>
                  </div>
                  <div class="prose max-w-none mb-4">
                    <%= content_with_hashtag_links(post.content) %>
                  </div>
                  <div class="card-actions justify-end mt-4">
                    <div class="flex space-x-4">
                      <%= render "shared/like_button", post: post %>
                      <button class="btn btn-ghost btn-sm">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                        </svg>
                        Reply
                      </button>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>

      <div class="mt-8">
        <%= paginate @posts %>
      </div>
    <% else %>
      <div class="text-center py-12">
        <div class="text-6xl mb-4">🔍</div>
        <h2 class="text-2xl font-semibold mb-2">No posts found</h2>
        <p class="opacity-70 mb-6">No posts have been tagged with #<%= @hashtag.name %> yet.</p>
        <%= link_to "Create the first post", new_post_path, class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>
</div>
