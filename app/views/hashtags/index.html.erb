<div class="container mx-auto px-4 py-8">
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-8">
      <h1 class="text-4xl font-bold mb-4">Popular Hashtags</h1>
      <p class="text-lg opacity-70">Discover trending topics and conversations</p>
    </div>

    <% if @hashtags.any? %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% @hashtags.each do |hashtag| %>
          <div class="card bg-base-100 shadow-xl hover:shadow-2xl transition-shadow">
            <div class="card-body">
              <h2 class="card-title text-primary">
                <%= link_to "##{hashtag.name}", hashtag_path(hashtag.name), class: "hover:text-primary-focus" %>
              </h2>
              <p class="text-sm opacity-70">
                <%= pluralize(hashtag.posts.count, 'post') %>
              </p>
              <div class="card-actions justify-end">
                <%= link_to "View Posts", hashtag_path(hashtag.name), class: "btn btn-primary btn-sm" %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-12">
        <div class="text-6xl mb-4">📝</div>
        <h2 class="text-2xl font-semibold mb-2">No hashtags yet</h2>
        <p class="opacity-70 mb-6">Start using hashtags in your posts to see them here!</p>
        <%= link_to "Create a Post", new_post_path, class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>
</div>
