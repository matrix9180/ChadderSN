<div class="max-w-4xl mx-auto">
  <%= render "shared/flash_messages" %>

  <div class="mb-6">
    <%= link_to posts_path, class: "btn btn-ghost btn-sm" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
      </svg>
      Back to Posts
    <% end %>
  </div>

  <div class="card bg-base-200 shadow-xl">
    <div class="card-body">
      <div class="flex items-start justify-between">
        <div class="flex items-center space-x-3">
          <div class="avatar placeholder">
            <div class="bg-neutral text-neutral-content rounded-full w-12">
              <span class="text-lg"><%= @post.author.display_name.first.upcase %></span>
            </div>
          </div>
          <div>
            <h3 class="font-bold">
              <%= link_to @post.author.display_name, user_path(@post.author), class: "link link-primary" %>
            </h3>
            <p class="text-sm text-base-content/70">
              @<%= @post.author.username %> • <%= time_ago_in_words(@post.created_at) %> ago
            </p>
          </div>
        </div>
        
        <% if @post.author == Current.user %>
          <div class="dropdown dropdown-end">
            <div tabindex="0" role="button" class="btn btn-ghost btn-sm">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v.01M12 12v.01M12 19v.01M12 6a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2z" />
              </svg>
            </div>
            <ul tabindex="0" class="dropdown-content z-[1] menu p-2 shadow bg-base-100 rounded-box w-52">
              <li>
                <%= button_to "Delete Post", post_path(@post), 
                    method: :delete, 
                    class: "text-error",
                    data: { confirm: "Are you sure you want to delete this post?" } %>
              </li>
            </ul>
          </div>
        <% end %>
      </div>
      
      <div class="mt-6">
        <p class="text-base-content whitespace-pre-wrap text-lg"><%= @post.content %></p>
      </div>
      
      <div class="card-actions justify-end mt-6">
        <div class="flex space-x-4">
          <%= render "shared/like_button", post: @post %>
          <button class="btn btn-ghost btn-sm">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
            </svg>
            Reply
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- More posts from this author -->
  <div class="mt-8">
    <h3 class="text-xl font-bold mb-4">More from <%= @post.author.display_name %></h3>
    <div class="space-y-4">
      <% @post.author.authored_posts.where.not(id: @post.id).limit(3).each do |post| %>
        <div class="card bg-base-100 shadow-sm">
          <div class="card-body">
            <div class="flex items-center space-x-3 mb-2">
              <div class="avatar placeholder">
                <div class="bg-neutral text-neutral-content rounded-full w-8">
                  <span class="text-sm"><%= post.author.display_name.first.upcase %></span>
                </div>
              </div>
              <div>
                <p class="text-sm text-base-content/70">
                  <%= time_ago_in_words(post.created_at) %> ago
                </p>
              </div>
            </div>
            <p class="text-base-content"><%= truncate(post.content, length: 150) %></p>
            <%= link_to "Read more", post_path(post), class: "link link-primary text-sm" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div> 