<div class="max-w-4xl mx-auto">
  <%= render "shared/page_header", 
      title: "Posts", 
      subtitle: "Latest posts from the community" %>
  
  <%= render "shared/flash_messages" %>

  <div class="flex justify-between items-center mb-6">
    <h2 class="text-2xl font-bold">Recent Posts</h2>
    <%= link_to new_post_path, class: "btn btn-primary" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
      </svg>
      New Post
    <% end %>
  </div>

  <div class="space-y-6">
    <% @posts.each do |post| %>
      <div class="card bg-base-200 shadow-xl">
        <div class="card-body">
          <div class="flex items-start justify-between">
            <div class="flex items-center space-x-3">
              <div class="avatar placeholder">
                <div class="bg-neutral text-neutral-content rounded-full w-12">
                  <span class="text-lg"><%= post.author.display_name.first.upcase %></span>
                </div>
              </div>
              <div>
                <h3 class="font-bold">
                  <%= link_to post.author.display_name, user_path(post.author), class: "link link-primary" %>
                </h3>
                <p class="text-sm text-base-content/70">
                  @<%= post.author.username %> • <%= time_ago_in_words(post.created_at) %> ago
                </p>
              </div>
            </div>
            
            <% if post.author == Current.user %>
              <div class="dropdown dropdown-end">
                <div tabindex="0" role="button" class="btn btn-ghost btn-sm">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v.01M12 12v.01M12 19v.01M12 6a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2z" />
                  </svg>
                </div>
                <ul tabindex="0" class="dropdown-content z-[1] menu p-2 shadow bg-base-100 rounded-box w-52">
                  <li>
                    <%= link_to "View Post", post_path(post) %>
                  </li>
                  <li>
                    <%= button_to "Delete Post", post_path(post), 
                        method: :delete, 
                        class: "text-error",
                        data: { confirm: "Are you sure you want to delete this post?" } %>
                  </li>
                </ul>
              </div>
            <% end %>
          </div>
          
          <div class="mt-4">
            <p class="text-base-content whitespace-pre-wrap"><%= post.content %></p>
          </div>
          
          <div class="card-actions justify-end mt-4">
            <div class="flex space-x-4">
              <button class="btn btn-ghost btn-sm">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                </svg>
                Like
              </button>
              <button class="btn btn-ghost btn-sm">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                </svg>
                Reply
              </button>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <% if @posts.empty? %>
    <div class="text-center py-12">
      <div class="text-6xl mb-4">📝</div>
      <h3 class="text-xl font-bold mb-2">No posts yet</h3>
      <p class="text-base-content/70 mb-6">Be the first to share something with the community!</p>
      <%= link_to "Create your first post", new_post_path, class: "btn btn-primary" %>
    </div>
  <% end %>

  <% if @posts.any? %>
    <%= paginate @posts %>
  <% end %>
</div> 